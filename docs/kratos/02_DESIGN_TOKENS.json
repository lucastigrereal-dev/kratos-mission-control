{
  "$schema": "https://raw.githubusercontent.com/lucastigrereal-dev/kratos/main/docs/kratos/design-tokens-schema.json",
  "name": "KRATOS Mission Control Design Tokens",
  "version": "1.0.0",
  "description": "Todos os tokens de design do KRATOS em JSON puro. Dark mode only.",

  "colors": {
