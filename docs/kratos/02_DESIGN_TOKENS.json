      "sky": { "value": "#60A5FA", "token": "--kr-sky" },
      "sky_light": { "value": "#93C5FD", "token": "--kr-sky-light" }
    },
    "island_terrain": {
      "grass": { "value": "#22C55E", "token": "--kr-grass" },
      "grass_light": { "value": "#4ADE80", "token": "--kr-grass-light" },
      "earth": { "value": "#92400E", "token": "--kr-earth" },
      "earth_dark": { "value": "#78350F", "token": "--kr-earth-dark" },
      "wood": { "value": "#A16207", "token": "--kr-wood" },
      "wood_light": { "value": "#CA8A04", "token": "--kr-wood-light" }
